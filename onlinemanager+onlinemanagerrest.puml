@startuml OnlineManager
allowmixing

skinparam packageStyle rectangle
skinparam classBackgroundColor #F8F8F8
skinparam classBorderColor #888
skinparam arrowColor #444
skinparam packageBorderColor #999
skinparam defaultFontSize 12

' =============================================
package "onlinemanagerrest (Java 24 · REST API)" #E6F1FB {

    class OnlinemanagerREST {
        +main(args: String[])
        ..
        HttpServer port 8080
        VirtualThreadPerTask
    }

    package "Handler" #D0E4F7 {
        class Login
        class Logout
        class getData
        class getDuplicate
        class getDuplicateSessions
        class getAcctStopTimeCandidate
        class correctionAcctStopTime
        class Hello
    }

    class TokenManager {
        -tokens: ConcurrentHashMap<String, Long>
        -TOKEN_EXPIRY_MS: long
        +generateToken(u, p): String
        +isValidToken(token): boolean
        +invalidateToken(token)
    }

    class HtpasswdVerifier {
        -htpasswdPath: Path
        +authenticate(u, p): boolean
        -verifyPassword(plain, hash): boolean
        -verifySha1(plain, hash): boolean
    }

    class Helpers {
        +logger: Logger
        +sendResponse(exchange, code, body)
        +sendUnifiedResponse(exchange, ...)
        +checkAuth(exchange): boolean
        +extractToken(header): String
        +localLog(exchange, msg)
    }

    class ParseParams {
        +getQueryParams(exchange): Map
        +getFormParams(exchange): Map
    }

    class jConfigSerializing_REST <<REST>> {
        +xmlName: String
        +htpasswdName: String
        +findFilePath(name): Path
        +resolveHtpasswdPath(): Path
        +load(): jConfig
        +save(config)
    }

    class jConfig_REST <<REST>> {
        +serverName: String
        +databaseName: String
        +username: String
        +password: String
    }

    class RadiusData_REST <<Singleton>> {
        -semaphore: Semaphore(3)
        -con: Connection
        +getInstance(): RadiusData
        +getData(...): List<SessionRow>
        +getDuplicateData(): List<DuplicateDataRow>
        +getDuplicateSessions(u): List<DuplicateSessionRow>
        +getAcctStopTimeCandidate(...): List
        +correctionAcctStopTime(id, t): boolean
        +reinit()
    }

    class SessionRow <<record>> {
        +radacctid: long
        +username: String
        +router: String
        +acctstarttime: String
        +acctstoptime: String
        +framedipaddress: String
    }

    class DuplicateDataRow <<record>> {
        +username: String
        +count: int
    }

    class AcctStopTimeCandidate <<record>> {
        +acctstarttime: String
        +acctstoptime_candidate: String
    }
}

' =============================================
package "onlinemanager (Java 21 · Swing desktop)" #EAF3DE {

    class Onlinemanager {
        +main(args: String[])
        ..
        OS check · JDBC check
        Java2D props
    }

    class jMainFrame {
        -timer: Timer
        -gridOnlinePanel: gridOnline
        +simpleRefresh()
        +fullRefresh()
        +checkStateAutoRefresh()
        +dispose()
    }

    class JFrameDuplicateCheck {
        -currentUsername: String
        -currentRadAcctID: Long
        -candidateAcctStopTime: String
        +jTableDuplicateSessionsLoadData()
        +jTableDuplicateSessionsSelectRow(row)
        +jTableUsernameDetailSelectRow(row)
    }

    class JSetup {
        ' налаштування DB + REST
    }

    class Timer {
        -jmf: jMainFrame
        -timer: javax.swing.Timer
        +start()
        +stop()
        ..
        60 сек · EDT · autoRefresh guard
    }

    class gridOnline {
        +loadData()
        +jTableOnlineSelectRow(row)
        +updateRowCountInfo()
    }

    class RestApiClient <<Singleton>> {
        -http: HttpClient
        -token: String
        -baseUrl: String
        +getInstance(): RestApiClient
        +login(u, p): boolean
        +getData(...): RestApiClient
        +getDuplicateData(...): RestApiClient
        +getDuplicateSessions(...): RestApiClient
        +getAcctStopTimeCandidate(...): RestApiClient
        +correctionAcctStopTime(id, t): RestApiClient
    }

    class jConfigSerializing_Desktop <<Desktop>> {
        +xmlName: String
        +load(): jConfig
        +save(config)
    }

    class jConfig_Desktop <<Desktop>> {
        +serverName: String
        +databaseName: String
        +restserverName: String
        +restApiUrl: String
        +restusername: String
        +restpassword: String
    }

    class RadiusData_Desktop <<Singleton>> {
        -semaphore: Semaphore(3)
        -con: Connection
        +getInstance(): RadiusData
        +getData(DFT, ...): RadiusData
        +getDuplicateData(DFT): RadiusData
        +correctionAcctStopTime(id, t): RadiusData
    }

    class VersionChecker {
        +checkForUpdates(frame)
        +getCurrentVersion(): String
        -isNewerVersion(l, c): boolean
    }

    class jCutCopyPaste {
        +actionCut: CutAction
        +actionCopy: CopyAction
        +actionPaste: PasteAction
        +actionSelectAll: SelectAllAction
    }

    class Html2Text {
        +getText(html): String
    }
}

' =============================================
' Зовнішні ресурси — тепер теж class, щоб не мішати типи
class htpasswd_txt <<file>> {
    DES / SHA-1 / bcrypt
}

class config_xml <<file>> {
    DB credentials
    REST credentials
}

class MySQL_DB <<database>> {
    radacct
    customers
    radacct_customers_link
}

' =============================================
' Зв'язки: REST handlers → сервіси
OnlinemanagerREST --> Login
OnlinemanagerREST --> Logout
OnlinemanagerREST --> getData
OnlinemanagerREST --> getDuplicate
OnlinemanagerREST --> getDuplicateSessions
OnlinemanagerREST --> getAcctStopTimeCandidate
OnlinemanagerREST --> correctionAcctStopTime
OnlinemanagerREST --> Hello

Login ..> TokenManager : generateToken()
Logout ..> TokenManager : invalidateToken()
getData ..> RadiusData_REST
getDuplicate ..> RadiusData_REST
getDuplicateSessions ..> RadiusData_REST
getAcctStopTimeCandidate ..> RadiusData_REST
correctionAcctStopTime ..> RadiusData_REST

Login ..> ParseParams
getData ..> ParseParams
getDuplicateSessions ..> ParseParams
getAcctStopTimeCandidate ..> ParseParams
correctionAcctStopTime ..> ParseParams

Login ..> Helpers
Logout ..> Helpers
getData ..> Helpers
getDuplicate ..> Helpers

TokenManager ..> HtpasswdVerifier : authenticate()
HtpasswdVerifier ..> jConfigSerializing_REST : resolveHtpasswdPath()
RadiusData_REST ..> jConfigSerializing_REST : load()
jConfigSerializing_REST ..> jConfig_REST
jConfigSerializing_REST ..> htpasswd_txt : reads
jConfigSerializing_REST ..> config_xml : reads/writes
RadiusData_REST --> MySQL_DB : JDBC

RadiusData_REST +-- SessionRow
RadiusData_REST +-- DuplicateDataRow
RadiusData_REST +-- AcctStopTimeCandidate

' =============================================
' Зв'язки: desktop
Onlinemanager --> jMainFrame : creates
jMainFrame --> gridOnline
jMainFrame --> Timer
jMainFrame --> VersionChecker
jMainFrame --> JFrameDuplicateCheck : opens
jMainFrame --> JSetup : opens
jMainFrame --> jCutCopyPaste

gridOnline ..> RestApiClient : loadData()
JFrameDuplicateCheck ..> RestApiClient
RestApiClient ..> jConfigSerializing_Desktop : load()
jConfigSerializing_Desktop ..> jConfig_Desktop
jConfigSerializing_Desktop ..> config_xml : reads/writes
RadiusData_Desktop --> MySQL_DB : JDBC (direct mode)

' =============================================
' Міжпроектний зв'язок
RestApiClient ..> OnlinemanagerREST : HTTPS POST\n/login · /getdata\n/getduplicate · /correctionacctstoptime

@enduml